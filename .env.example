# ============================================================
# LexAI India — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ── Anthropic (REQUIRED for AI agents) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase (REQUIRED for database + auth) ─────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── AWS S3 (REQUIRED for document storage) ──────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_S3_BUCKET=lexai-documents-prod

# ── Redis / Upstash (REQUIRED for job queue) ─────────────────
REDIS_URL=redis://default:...@...upstash.io:6379

# ── Voyage AI (REQUIRED for embeddings) ─────────────────────
VOYAGE_API_KEY=pa-...

# ── LlamaParse (REQUIRED for document OCR) ──────────────────
LLAMA_CLOUD_API_KEY=llx-...

# ── Firebase (REQUIRED for push notifications) ───────────────
FIREBASE_PROJECT_ID=lexai-india
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@lexai-india.iam.gserviceaccount.com

# ── Resend (REQUIRED for email) ──────────────────────────────
RESEND_API_KEY=re_...

# ── Razorpay (REQUIRED for billing) ─────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── MSG91 (REQUIRED for OTP + SMS) ──────────────────────────
MSG91_AUTH_KEY=...
MSG91_SENDER_ID=LEXAII

# ── WhatsApp Business API (Phase 2) ─────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── App Config ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
JWT_SECRET=change-this-to-a-random-32-char-string-in-production
CORS_ORIGIN=http://localhost:3000

# ── PostHog Analytics (optional) ────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sentry (optional) ────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
