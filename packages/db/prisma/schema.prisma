// ============================================================
// LexAI India — Prisma Database Schema
// PRD v1.1 | Master Schema v1.0 + Addendum v1.1
// PostgreSQL 16 via Supabase
// Run: npx prisma migrate dev --name init
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgvector(map: "vector")]
}

// ── ENUMS ────────────────────────────────────────────────────

enum TenantPlan {
  starter
  professional
  enterprise
}

enum UserRole {
  super_admin
  managing_partner
  senior_advocate
  junior_associate
  clerk
  client
}

enum CaseType {
  criminal_sessions
  criminal_magistrate
  civil_district
  writ_hc
  corporate_nclt
  family
  labour
  ip
  tax
  arbitration
  consumer
}

enum CourtLevel {
  supreme_court
  high_court
  district_court
  tribunal
  magistrate
}

enum CaseStatus {
  intake
  filed
  pending_hearing
  arguments
  reserved
  decided
  appeal
  closed
}

enum CasePriority {
  low
  normal
  high
  urgent
}

enum CasePerspective {
  defence
  prosecution
  petitioner
  respondent
  appellant
  claimant
}

enum DocCategory {
  fir
  chargesheet
  bail_order
  witness_statement
  forensic_report
  affidavit
  plaint
  written_statement
  vakalatnama
  order
  judgment
  deposition
  evidence_exhibit
  consultation_recording
  other
}

enum DocumentProcessingStatus {
  pending
  processing
  ready
  failed
}

enum HearingPurpose {
  framing_of_charges
  bail
  arguments
  judgment
  evidence
  examination
  cross_examination
  interim_order
  return_of_summons
  misc
}

enum TaskStatus {
  todo
  in_progress
  review
  done
  cancelled
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

enum TaskType {
  drafting
  filing
  hearing_prep
  research
  correspondence
  admin
  other
}

enum AgentType {
  evidence
  timeline
  deposition
  research
  strategy
}

enum AgentStatus {
  queued
  running
  completed
  failed
  cancelled
}

enum DraftDocType {
  bail_application
  plaint
  written_statement
  writ_petition
  affidavit
  vakalatnama
  opening_statement
  closing_statement
  rejoinder
  memo_of_appeal
  other
}

enum AnnotationColor {
  yellow
  red
  green
  blue
  purple
}

enum NotificationType {
  hearing_reminder_30d
  hearing_reminder_7d
  hearing_reminder_1d
  hearing_day_briefing
  task_due_tomorrow
  task_overdue
  agent_completed
  agent_failed
  case_status_changed
  draft_locked
  mention
  ecourts_sync_conflict
  system
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing
  suspended
}

enum InvoiceStatus {
  draft
  issued
  paid
  partially_paid
  overdue
  cancelled
}

enum PaymentMode {
  upi
  neft
  rtgs
  cheque
  cash
  razorpay
  other
}

enum IdProofType {
  aadhaar
  pan
  passport
  driving_licence
  voter_id
  other
}

enum ClientRole {
  accused
  complainant
  petitioner
  respondent
  appellant
  witness
  other
}

enum CourtPortal {
  ecourts
  nclt
  drt
  supreme_court
  high_court_delhi
  high_court_bombay
  high_court_madras
  high_court_calcutta
  other
}

enum CourtSyncStatus {
  running
  success
  failed
  portal_unavailable
  cnr_not_found
}

enum WhatsAppMessageType {
  cause_list_summary
  hearing_reminder_7d
  hearing_reminder_2d
  outcome_update
  invoice_reminder
  payment_confirmation
}

enum WaDeliveryStatus {
  queued
  sent
  delivered
  read
  failed
}

enum ClientNotificationType {
  hearing_reminder_7d
  hearing_reminder_2d
  outcome_update
  document_shared
  invoice_issued
  invoice_overdue
  custom
}

// ── TABLES ───────────────────────────────────────────────────

// Schema 1: Tenants (law firms)
model Tenant {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String    @db.VarChar(255)
  slug                  String    @unique @db.VarChar(100)
  plan                  TenantPlan @default(starter)
  settings              Json      @default("{}")
  active                Boolean   @default(true)
  razorpay_customer_id  String?   @db.VarChar(100)
  created_at            DateTime  @default(now()) @db.Timestamptz(6)

  // Relations
  users                 User[]
  cases                 Case[]
  subscriptions         Subscription[]
  notifications         Notification[]
  agent_jobs            AgentJob[]
  drafts                Draft[]
  presentations         Presentation[]
  clients               Client[]
  court_sync_jobs       CourtSyncJob[]
  whatsapp_messages     WhatsAppMessage[]
  client_notifications  ClientNotification[]
  invoices              Invoice[]
  audit_logs            AuditLog[]

  @@map("tenants")
}

// Schema 2: Users (advocates, clerks, clients with portal access)
model User {
  id                String    @id @db.Uuid  // matches Supabase auth.users.id
  tenant_id         String    @db.Uuid
  email             String    @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  full_name         String    @db.VarChar(255)
  role              UserRole
  bar_enrollment_no String?   @db.VarChar(50)
  avatar_url        String?
  is_active         Boolean   @default(true)
  last_seen_at      DateTime? @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)

  tenant            Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  // Relations — cases this user is assigned to
  created_cases     Case[]    @relation("CaseCreatedBy")
  tasks_assigned    Task[]    @relation("TaskAssignedTo")
  created_tasks     Task[]    @relation("TaskCreatedBy")
  uploaded_docs     Document[]
  annotations       Annotation[]
  created_drafts    Draft[]   @relation("DraftCreatedBy")
  agent_jobs        AgentJob[]
  notifications     Notification[]
  // Client portal user may be linked from Client record
  client_profile    Client?   @relation("ClientPortalUser")
  created_invoices  Invoice[]
  recorded_payments InvoicePayment[]
  audit_logs        AuditLog[]

  @@unique([tenant_id, email])
  @@map("users")
}

// Schema 3: Cases
model Case {
  id                          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                   String          @db.Uuid
  cnr_number                  String?         @db.VarChar(30)
  title                       String          @db.VarChar(500)
  case_type                   CaseType
  court                       String          @db.VarChar(200)
  court_level                 CourtLevel
  judge_name                  String?         @db.VarChar(255)
  status                      CaseStatus      @default(intake)
  priority                    CasePriority    @default(normal)
  perspective                 CasePerspective @default(defence)
  filed_date                  DateTime?       @db.Date
  next_hearing_date           DateTime?       @db.Date
  assigned_advocates          String[]        @db.Uuid   // array of user IDs
  client_id                   String?         @db.Uuid
  parent_case_id              String?         @db.Uuid
  metadata                    Json            @default("{}")
  client_instruction_default  String?
  ecourts_sync_enabled        Boolean         @default(true)
  last_synced_at              DateTime?       @db.Timestamptz(6)
  created_by                  String          @db.Uuid
  created_at                  DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime        @updatedAt @db.Timestamptz(6)

  tenant                      Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  creator                     User            @relation("CaseCreatedBy", fields: [created_by], references: [id])
  parent_case                 Case?           @relation("CaseAppeals", fields: [parent_case_id], references: [id])
  child_cases                 Case[]          @relation("CaseAppeals")

  // Relations
  documents                   Document[]
  hearings                    Hearing[]
  tasks                       Task[]
  agent_jobs                  AgentJob[]
  drafts                      Draft[]
  presentations               Presentation[]
  timeline_events             TimelineEvent[]
  evidence_items              EvidenceItem[]
  legal_citations             LegalCitation[]
  annotations                 Annotation[]
  notifications               Notification[]
  court_sync_jobs             CourtSyncJob[]
  client_notifications        ClientNotification[]
  invoices                    Invoice[]
  case_clients                CaseClient[]

  @@unique([tenant_id, cnr_number])
  @@index([tenant_id, status])
  @@index([tenant_id, next_hearing_date])
  @@index([tenant_id, case_type])
  @@map("cases")
}

// Schema 4: Documents
model Document {
  id                    String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String                    @db.Uuid
  case_id               String                    @db.Uuid
  filename              String                    @db.VarChar(500)
  s3_key                String                    @unique
  mime_type             String                    @db.VarChar(100)
  file_size_bytes       BigInt
  doc_category          DocCategory?
  processing_status     DocumentProcessingStatus  @default(pending)
  extracted_text        String?
  page_count            Int?
  shared_with_client    Boolean                   @default(false)
  version_number        Int                       @default(1)
  previous_version_id   String?                   @db.Uuid
  uploaded_by           String                    @db.Uuid
  created_at            DateTime                  @default(now()) @db.Timestamptz(6)

  // Embedding stored as raw SQL — pgvector not directly in Prisma schema
  // embedding vector(1536) — added via raw migration

  tenant                Tenant                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  case                  Case                      @relation(fields: [case_id], references: [id], onDelete: Cascade)
  uploader              User                      @relation(fields: [uploaded_by], references: [id])
  previous_version      Document?                 @relation("DocumentVersions", fields: [previous_version_id], references: [id])
  newer_versions        Document[]                @relation("DocumentVersions")
  annotations           Annotation[]
  tags                  DocumentTag[]

  @@index([tenant_id, case_id])
  @@index([case_id, doc_category])
  @@index([processing_status])
  @@map("documents")
}

// Schema 5: Hearings
model Hearing {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String          @db.Uuid
  case_id               String          @db.Uuid
  date                  DateTime        @db.Date
  time                  String?         @db.VarChar(5)   // HH:MM
  court_room            String?         @db.VarChar(100)
  judge_name            String?         @db.VarChar(255)
  purpose               HearingPurpose
  outcome               String?
  order_summary         String?
  client_instruction    String?
  reminder_30d_sent     Boolean         @default(false)
  reminder_7d_sent      Boolean         @default(false)
  reminder_1d_sent      Boolean         @default(false)
  created_by            String          @db.Uuid
  created_at            DateTime        @default(now()) @db.Timestamptz(6)

  tenant                Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  case                  Case            @relation(fields: [case_id], references: [id], onDelete: Cascade)
  tasks                 Task[]
  notifications         Notification[]
  client_notifications  ClientNotification[]
  court_sync_jobs       CourtSyncJob[]

  @@index([tenant_id, date])
  @@index([case_id, date])
  @@map("hearings")
}

// Schema 6: Tasks
model Task {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String        @db.Uuid
  case_id             String        @db.Uuid
  title               String        @db.VarChar(500)
  description         String?
  task_type           TaskType?
  status              TaskStatus    @default(todo)
  priority            TaskPriority  @default(normal)
  assigned_to         String[]      @db.Uuid
  due_date            DateTime?     @db.Date
  linked_hearing_id   String?       @db.Uuid
  from_template       Boolean       @default(false)
  comments            Json          @default("[]")  // TaskComment[]
  created_by          String        @db.Uuid
  created_at          DateTime      @default(now()) @db.Timestamptz(6)
  completed_at        DateTime?     @db.Timestamptz(6)

  tenant              Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  case                Case          @relation(fields: [case_id], references: [id], onDelete: Cascade)
  creator             User          @relation("TaskCreatedBy", fields: [created_by], references: [id])
  assigned_user       User?         @relation("TaskAssignedTo", fields: [created_by], references: [id])
  linked_hearing      Hearing?      @relation(fields: [linked_hearing_id], references: [id])

  @@index([tenant_id, status])
  @@index([case_id, status])
  @@index([due_date])
  @@map("tasks")
}

// Schema 7: Agent Jobs
model AgentJob {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String      @db.Uuid
  case_id         String      @db.Uuid
  agent_type      AgentType
  agent_version   String      @db.VarChar(50)  // e.g. "AGENT_EVIDENCE_V1"
  status          AgentStatus @default(queued)
  triggered_by    String      @db.VarChar(40)  // UUID or "auto"
  input_config    Json        @default("{}")
  output          Json?
  tokens_input    Int?
  tokens_output   Int?
  model_used      String      @default("claude-sonnet-4-6") @db.VarChar(50)
  cost_inr        Decimal?    @db.Decimal(10, 2)
  error_message   String?
  started_at      DateTime?   @db.Timestamptz(6)
  completed_at    DateTime?   @db.Timestamptz(6)
  created_at      DateTime    @default(now()) @db.Timestamptz(6)

  tenant          Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  case            Case        @relation(fields: [case_id], references: [id], onDelete: Cascade)
  triggered_user  User?       @relation(fields: [triggered_by], references: [id])

  @@index([tenant_id, case_id])
  @@index([status])
  @@index([agent_type])
  @@map("agent_jobs")
}

// Timeline Events (Evidence Agent output → structured rows)
model TimelineEvent {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id           String    @db.Uuid
  agent_job_id      String    @db.Uuid
  event_date        DateTime  @db.Date
  event_time        String?   @db.VarChar(5)
  description       String
  source_doc_id     String?   @db.Uuid
  source_page       Int?
  event_type        String    @db.VarChar(50)
  importance_score  Decimal   @db.Decimal(3, 2)
  gap_after_minutes Int?
  created_at        DateTime  @default(now()) @db.Timestamptz(6)

  case              Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id, event_date])
  @@map("timeline_events")
}

// Evidence Items (Evidence Agent output → structured rows)
model EvidenceItem {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id               String    @db.Uuid
  agent_job_id          String    @db.Uuid
  exhibit_number        String    @db.VarChar(20)   // e.g. "E-1", "MO-3"
  description           String
  source_doc_id         String?   @db.Uuid
  source_page           Int?
  extracted_by_agent    Boolean   @default(true)
  verified_by           String?   @db.Uuid
  category              String?   @db.VarChar(10)   // E-, MO-, X-, C-
  contradicts_item_id   String?   @db.Uuid
  created_at            DateTime  @default(now()) @db.Timestamptz(6)

  case                  Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@map("evidence_items")
}

// Legal Citations (Research Agent output → structured rows)
model LegalCitation {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_id           String    @db.Uuid
  agent_job_id      String    @db.Uuid
  citation_string   String    @db.VarChar(200)
  court             String    @db.VarChar(100)
  year              Int
  full_citation     String?
  relevance_score   Decimal   @db.Decimal(3, 2)
  summary           String?
  source            String    @db.VarChar(20)    // scc, hc, manual
  url               String?
  is_favorable      Boolean   @default(true)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)

  case              Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
  @@map("legal_citations")
}

// Schema 9: Drafts
model Draft {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String        @db.Uuid
  case_id             String        @db.Uuid
  title               String        @db.VarChar(500)
  doc_type            DraftDocType?
  content             Json          // TipTap ProseMirror JSON
  version             Int           @default(1)
  word_count          Int           @default(0)
  is_locked           Boolean       @default(false)
  locked_by           String?       @db.Uuid
  locked_at           DateTime?     @db.Timestamptz(6)
  promoted_from_job   String?       @db.Uuid
  created_by          String        @db.Uuid
  last_modified_by    String        @db.Uuid
  last_modified_at    DateTime      @default(now()) @db.Timestamptz(6)
  created_at          DateTime      @default(now()) @db.Timestamptz(6)

  tenant              Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  case                Case          @relation(fields: [case_id], references: [id], onDelete: Cascade)
  creator             User          @relation("DraftCreatedBy", fields: [created_by], references: [id])
  versions            DraftVersion[]
  annotations         Annotation[]

  @@index([tenant_id, case_id])
  @@map("drafts")
}

model DraftVersion {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  draft_id        String    @db.Uuid
  version         Int
  content         Json
  snapshot_by     String    @db.Uuid
  snapshot_at     DateTime  @default(now()) @db.Timestamptz(6)
  change_summary  String?

  draft           Draft     @relation(fields: [draft_id], references: [id], onDelete: Cascade)

  @@index([draft_id, version])
  @@map("draft_versions")
}

// Schema 10: Annotations
model Annotation {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String          @db.Uuid
  document_id     String?         @db.Uuid
  draft_id        String?         @db.Uuid
  case_id         String          @db.Uuid
  user_id         String          @db.Uuid
  text            String
  highlight_from  Int
  highlight_to    Int
  page_number     Int?
  color           AnnotationColor @default(yellow)
  resolved        Boolean         @default(false)
  created_at      DateTime        @default(now()) @db.Timestamptz(6)

  document        Document?       @relation(fields: [document_id], references: [id], onDelete: Cascade)
  draft           Draft?          @relation(fields: [draft_id], references: [id], onDelete: Cascade)
  case            Case            @relation(fields: [case_id], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [user_id], references: [id])

  @@index([document_id])
  @@index([draft_id])
  @@map("annotations")
}

// Schema 11: Presentations
model Presentation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  case_id         String    @db.Uuid
  title           String    @db.VarChar(500)
  slides          Json      @default("[]")   // Slide[]
  is_shared       Boolean   @default(false)
  share_token     String?   @db.Uuid
  share_expires_at DateTime? @db.Timestamptz(6)
  created_by      String    @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz(6)

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  case            Case      @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, case_id])
  @@map("presentations")
}

// Schema 12: Notifications (in-app, for advocates/staff)
model Notification {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String            @db.Uuid
  user_id             String            @db.Uuid
  type                NotificationType
  title               String            @db.VarChar(255)
  message             String
  read                Boolean           @default(false)
  action_url          String?
  related_case_id     String?           @db.Uuid
  related_hearing_id  String?           @db.Uuid
  created_at          DateTime          @default(now()) @db.Timestamptz(6)

  tenant              Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  related_case        Case?             @relation(fields: [related_case_id], references: [id])
  related_hearing     Hearing?          @relation(fields: [related_hearing_id], references: [id])

  @@index([user_id, read])
  @@index([tenant_id, created_at])
  @@map("notifications")
}

// Schema 13: Audit Logs — APPEND ONLY, NEVER DELETE
model AuditLog {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  user_id       String?   @db.Uuid  // null for system actions
  action        String    @db.VarChar(100)  // e.g. "CASE_CREATED", "AGENT_RUN"
  entity_type   String    @db.VarChar(50)
  entity_id     String    @db.Uuid
  old_value     Json?
  new_value     Json?
  ip_address    String?   @db.VarChar(45)
  user_agent    String?   @db.VarChar(500)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  tenant        Tenant    @relation(fields: [tenant_id], references: [id])
  user          User?     @relation(fields: [user_id], references: [id])

  @@index([tenant_id, created_at])
  @@index([entity_type, entity_id])
  @@map("audit_logs")
}

// Schema 15: Subscriptions
model Subscription {
  id                              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                       String             @unique @db.Uuid
  razorpay_subscription_id        String?            @db.VarChar(100)
  plan                            TenantPlan         @default(starter)
  status                          SubscriptionStatus @default(trialing)
  trial_ends_at                   DateTime?          @db.Timestamptz(6)
  current_period_start            DateTime           @db.Timestamptz(6)
  current_period_end              DateTime           @db.Timestamptz(6)
  cancel_at_period_end            Boolean            @default(false)
  agent_runs_this_period          Int                @default(0)
  storage_bytes_used              BigInt             @default(0)
  whatsapp_messages_this_period   Int                @default(0)
  invoices_this_period            Int                @default(0)
  created_at                      DateTime           @default(now()) @db.Timestamptz(6)

  tenant                          Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ── v1.1 NEW TABLES ──────────────────────────────────────────

// Schema 16: Clients
model Client {
  id                        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                 String          @db.Uuid
  full_name                 String          @db.VarChar(255)
  phone                     String          @db.VarChar(20)
  email                     String?         @db.VarChar(255)
  address                   String?
  id_proof_type             IdProofType?
  id_proof_number           String?         @db.VarChar(100)
  id_proof_s3_key           String?
  portal_user_id            String?         @unique @db.Uuid
  preferred_language        String          @default("english") @db.VarChar(10)
  whatsapp_opted_in         Boolean         @default(true)
  whatsapp_opted_out_at     DateTime?       @db.Timestamptz(6)
  sms_opted_in              Boolean         @default(true)
  email_opted_in            Boolean         @default(true)
  notification_prefs        Json            @default("{}")
  notes                     String?
  engaged_since             DateTime?       @db.Date
  outstanding_balance_paise BigInt          @default(0)
  created_by                String          @db.Uuid
  created_at                DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                DateTime        @updatedAt @db.Timestamptz(6)

  tenant                    Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  portal_user               User?           @relation("ClientPortalUser", fields: [portal_user_id], references: [id])
  case_links                CaseClient[]
  notifications             ClientNotification[]
  invoices                  Invoice[]
  invoice_payments          InvoicePayment[]

  @@index([tenant_id, full_name])
  @@index([tenant_id, phone])
  @@map("clients")
}

model CaseClient {
  case_id     String      @db.Uuid
  client_id   String      @db.Uuid
  role        ClientRole  @default(accused)
  added_by    String      @db.Uuid
  added_at    DateTime    @default(now()) @db.Timestamptz(6)

  case        Case        @relation(fields: [case_id], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@id([case_id, client_id])
  @@map("case_clients")
}

// Schema 17: Court Sync Jobs
model CourtSyncJob {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String          @db.Uuid
  case_id             String          @db.Uuid
  cnr_number          String          @db.VarChar(30)
  court_portal        CourtPortal
  trigger             String          @db.VarChar(10)  // scheduled | manual
  status              CourtSyncStatus
  fetched_date        DateTime?       @db.Date
  fetched_time        String?         @db.VarChar(5)
  fetched_court_room  String?         @db.VarChar(100)
  fetched_status      String?         @db.VarChar(200)
  fetched_order_date  DateTime?       @db.Date
  conflict_detected   Boolean         @default(false)
  auto_updated        Boolean         @default(false)
  error_message       String?
  response_time_ms    Int?
  synced_at           DateTime        @default(now()) @db.Timestamptz(6)

  tenant              Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  case                Case            @relation(fields: [case_id], references: [id], onDelete: Cascade)
  hearing             Hearing?        @relation(fields: [case_id], references: [case_id])

  @@index([tenant_id, synced_at])
  @@index([case_id])
  @@map("court_sync_jobs")
}

// Schema 18: WhatsApp Messages
model WhatsAppMessage {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String              @db.Uuid
  recipient_phone       String              @db.VarChar(20)
  recipient_type        String              @db.VarChar(10)  // advocate | client
  recipient_id          String              @db.Uuid
  message_type          WhatsAppMessageType
  template_name         String              @db.VarChar(100)
  template_variables    Json                @default("{}")
  wa_message_id         String?             @db.VarChar(200)
  delivery_status       WaDeliveryStatus    @default(queued)
  delivered_at          DateTime?           @db.Timestamptz(6)
  read_at               DateTime?           @db.Timestamptz(6)
  failure_reason        String?
  related_case_id       String?             @db.Uuid
  related_hearing_id    String?             @db.Uuid
  attachment_s3_key     String?
  sent_at               DateTime            @default(now()) @db.Timestamptz(6)

  tenant                Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, sent_at])
  @@index([delivery_status])
  @@map("whatsapp_messages")
}

// Schema 19: Client Notifications
model ClientNotification {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String                  @db.Uuid
  client_id             String                  @db.Uuid
  case_id               String?                 @db.Uuid
  hearing_id            String?                 @db.Uuid
  notification_type     ClientNotificationType
  channels_attempted    String[]                // whatsapp | sms | email
  whatsapp_message_id   String?                 @db.Uuid
  sms_status            String                  @default("not_sent") @db.VarChar(20)
  sms_provider_id       String?                 @db.VarChar(100)
  email_status          String                  @default("not_sent") @db.VarChar(20)
  email_message_id      String?                 @db.VarChar(100)
  content_snapshot      Json                    @default("{}")
  client_instruction    String?
  scheduled_for         DateTime                @db.Timestamptz(6)
  sent_at               DateTime?               @db.Timestamptz(6)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)

  tenant                Tenant                  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client                Client                  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  case                  Case?                   @relation(fields: [case_id], references: [id])
  hearing               Hearing?                @relation(fields: [hearing_id], references: [id])

  @@index([client_id, scheduled_for])
  @@index([notification_type, sent_at])
  @@map("client_notifications")
}

// Schema 20: Invoices
model Invoice {
  id                        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                 String        @db.Uuid
  client_id                 String        @db.Uuid
  case_id                   String?       @db.Uuid
  invoice_number            String        @db.VarChar(50)
  invoice_date              DateTime      @db.Date
  due_date                  DateTime?     @db.Date
  status                    InvoiceStatus @default(draft)
  line_items                Json          @default("[]")   // InvoiceLineItem[]
  subtotal_paise            BigInt        @default(0)
  gst_rate                  Int           @default(18)     // 0, 5, or 18
  gst_amount_paise          BigInt        @default(0)
  total_paise               BigInt        @default(0)
  amount_paid_paise         BigInt        @default(0)
  balance_paise             BigInt        @default(0)
  firm_gstin                String?       @db.VarChar(20)
  bank_account_details      Json?
  upi_qr_s3_key             String?
  pdf_s3_key                String?
  notes                     String?
  razorpay_payment_link     String?
  reminder_sent_dates       DateTime[]    @db.Date
  cancelled_at              DateTime?     @db.Timestamptz(6)
  cancelled_by              String?       @db.Uuid
  created_by                String        @db.Uuid
  created_at                DateTime      @default(now()) @db.Timestamptz(6)
  issued_at                 DateTime?     @db.Timestamptz(6)

  tenant                    Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  client                    Client        @relation(fields: [client_id], references: [id])
  case                      Case?         @relation(fields: [case_id], references: [id])
  creator                   User          @relation(fields: [created_by], references: [id])
  payments                  InvoicePayment[]

  @@unique([tenant_id, invoice_number])
  @@index([tenant_id, status])
  @@index([client_id, status])
  @@map("invoices")
}

// Schema 21: Invoice Payments
model InvoicePayment {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String      @db.Uuid
  invoice_id            String      @db.Uuid
  client_id             String      @db.Uuid
  amount_paise          BigInt
  payment_date          DateTime    @db.Date
  payment_mode          PaymentMode
  reference_number      String?     @db.VarChar(100)
  notes                 String?
  recorded_by           String      @db.Uuid
  razorpay_payment_id   String?     @db.VarChar(100)
  created_at            DateTime    @default(now()) @db.Timestamptz(6)

  invoice               Invoice     @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  client                Client      @relation(fields: [client_id], references: [id])
  recorder              User        @relation(fields: [recorded_by], references: [id])

  @@index([invoice_id])
  @@index([client_id])
  @@map("invoice_payments")
}

// Schema 22: Document Tags
model DocumentTag {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  document_id   String    @db.Uuid
  tag           String    @db.VarChar(50)
  created_by    String    @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz(6)

  document      Document  @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@unique([document_id, tag])
  @@index([tenant_id, tag])
  @@map("document_tags")
}
